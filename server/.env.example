# Vortex server configuration — copy to .env and fill real values.
# NEVER commit .env. In production set APP_ENV=production, which makes the
# server refuse to start if any secret below is still a default.

APP_ENV=development
PORT=8080
# Comma-separated. In prod use explicit origins: https://app.example.com
CORS_ALLOWED_ORIGINS=*

# ─── PostgreSQL ───
DATABASE_URL=postgres://vortex:CHANGE_ME@postgres:5432/vortex?sslmode=disable

# ─── Redis ───
REDIS_URL=redis://default:CHANGE_ME@redis:6379

# ─── JWT (access-token signing) — generate: openssl rand -hex 32 ───
JWT_SECRET=CHANGE_ME

# ─── Centrifugo (must match deploy/centrifugo/config.json) ───
CENTRIFUGO_API_URL=http://centrifugo:8000/api
CENTRIFUGO_API_KEY=CHANGE_ME
CENTRIFUGO_SECRET=CHANGE_ME

# ─── MinIO / S3 ───
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=vortex-media
MINIO_USE_SSL=false
# Public base URL clients use to download media (put behind your proxy in prod)
MEDIA_PUBLIC_URL=http://localhost:9000
